@page "/stock"
@using OcsStore.Models
@model OcsStore.Pages.StockModel
@{
}
<style>
    #gridStock .dx-toolbar-items-container {
        display: none;
    }
    #timeBox {
        margin-left: 0.5rem;
    }
    a.stock-link {
        padding-left: 0.1rem;
        padding-right: 0.2rem;
    }
    a.stock-link:active, a.stock-link:hover {
        color: inherit;
    }
    a.stock-link:active {
        text-decoration: none;
    }
</style>

<div id="divCaption" class="d-flex align-items-center pb-3">
    <h5>TỒN KHO</h5>
</div>

@(
Html.DevExtreme().DataGrid<StockView>()
    .ID("gridStock")
    .DataSource(d => d.Mvc().Controller("Stock").LoadAction("GetStocks").LoadMethod("POST"))
    .RemoteOperations(false)
    .ShowBorders(true)
    .ShowRowLines(true)
    .WordWrapEnabled(true)
    .Sorting(s => s.Mode(GridSortingMode.None))
    .Paging(p => p.PageSize(100))
    .Pager(p => p.Visible(false))
    .OnContentReady("gridContentReady")
    .Columns(columns =>
    {
        columns.AddFor(m => m.GroupName).Caption("Nhóm").Width(140).GroupIndex(0).CellTemplate(new JS("stockCellTemplate"));
        @* columns.Add().Caption("").Width(30).Alignment(HorizontalAlignment.Center).FixedPosition(HorizontalEdge.Left).Fixed(true).CellTemplate(new JS("stockLinkCellTemplate")); *@
        columns.AddFor(m => m.ItemName).Caption("Hàng hóa").Width(120).Alignment(HorizontalAlignment.Left).FixedPosition(HorizontalEdge.Left).Fixed(true).CellTemplate(new JS("stockCellTemplate"));
        @* columns.AddFor(m => m.UnitName).Caption("").Width(40).Alignment(HorizontalAlignment.Left); *@
        columns.Add().Caption("Tồn kho").Columns(cols =>
        {
            cols.AddFor(m => m.Soh).Caption("Số lượng").Width(60).Alignment(HorizontalAlignment.Right).Format("#,##0.00").CellTemplate(new JS("stockCellTemplate"));
            cols.AddFor(m => m.Ave).Caption("Giá TB").Width(64).Alignment(HorizontalAlignment.Right).Format("#,##0").CellTemplate(new JS("stockCellTemplate"));
            cols.AddFor(m => m.Value).Caption("Giá trị").Width(86).Alignment(HorizontalAlignment.Right).Format("#,##0").CellTemplate(new JS("stockCellTemplate"));
        });
        columns.AddFor(m => m.Date).Caption("Ngày").Width(90).Alignment(HorizontalAlignment.Center).Format("dd/MM/yyyy").CellTemplate(new JS("stockCellTemplate"));
        columns.AddFor(m => m.Time).Caption("Giờ").Width(50).Alignment(HorizontalAlignment.Center).CellTemplate(new JS("stockCellTemplate"));
    })
    .Editing(e => e.AllowUpdating(false))
    .Paging(p => p.Enabled(true).PageSize(100))
)

<script>
    $(function () {
        $("#gridStock").first().prepend($("#divCaption"));
    });

    function gridContentReady() {
        $(".dx-header-row > td").css("text-align", "center");
    }

    function onCellPrepared(e) {
        if (e.rowType === 'group' && e.column.command === 'expand') {
            e.cellElement.css('display', 'none');
        }
    }

    function stockCellTemplate(container, options) {
        let itemIsInput = options.data.ItemIsInput;
        let itemIsOutput = options.data.ItemIsOutput;
        let isInOutColumn = (options.column.dataField == "InOut");
        let cssClass = (itemIsInput ? "green2" : (itemIsOutput ? "dark-blue" : "brown"));
        let style = "";
        let text = options.text;
        let lot = options.data.Lot;
        if (lot != "") {
            cssClass += " ps-1";
            style = "font-size: 0.9rem;"
            if (options.column.dataField == "ItemName") {
                text = "•  " + text;
            }
        }
        
        if (options.column.dataField == "ItemName") {
            text = `<a class='stock-link' href='/stockcard?item=${options.data.Item}&lot=${options.data.Lot}&year=${options.data.Year}'><span class='${cssClass}'>${text}</span></a>`;
        }
        
        let html = `<div class='${cssClass}' style='${style}'>${text}</div>`
        container.html(html);
    }

    // function stockLinkCellTemplate(container, options) {
    //     let itemIsInput = options.data.ItemIsInput;
    //     let itemIsOutput = options.data.ItemIsOutput;
    //     let cssClass = (itemIsInput ? "green2" : (itemIsOutput ? "dark-blue" : "brown"));
    //     let html = `<a class='stock-link' href='/stockcard?item=${options.data.Item}&lot=${options.data.Lot}&year=${options.data.Year}'><i class='dx-icon-find ${cssClass}'></i></a>`;
    //     container.html(html);
    // }
</script>