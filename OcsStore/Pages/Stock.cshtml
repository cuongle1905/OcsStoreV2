@page "/stock"
@using OcsStore.Models
@model OcsStore.Pages.StockModel
@{
}
<style>
    #gridStock .dx-toolbar-items-container {
        display: none;
    }
    #timeBox {
        margin-left: 0.5rem;
    }
    a.stock-link {
        padding-left: 0.1rem;
        padding-right: 0.2rem;
    }
    a.icon-link:hover {
        text-decoration: none;
    }
</style>

<div id="divCaption" class="d-flex align-items-center pb-3">
    <h5>TỒN KHO</h5>
</div>

@(
Html.DevExtreme().DataGrid<StockView>()
    .ID("gridStock")
    .DataSource(d => d.Mvc().Controller("Stock").LoadAction("GetStocks").LoadMethod("POST"))
    .RemoteOperations(false)
    .ShowBorders(true)
    .ShowRowLines(true)
    .WordWrapEnabled(true)
    .Sorting(s => s.Mode(GridSortingMode.None))
    .Paging(p => p.PageSize(100))
    .Pager(p => p.Visible(false))
    .OnContentReady("gridContentReady")
    .Columns(columns =>
    {
        columns.AddFor(m => m.GroupName).Caption("Nhóm").Width(140).GroupIndex(0).CellTemplate(new JS("stockCellTemplate"));
        @* columns.Add().Caption("").Width(30).Alignment(HorizontalAlignment.Center).FixedPosition(HorizontalEdge.Left).Fixed(true).CellTemplate(new JS("stockLinkCellTemplate")); *@
        columns.AddFor(m => m.ItemName).Caption("Hàng hóa").Width(120).Alignment(HorizontalAlignment.Left).Fixed(true).FixedPosition(HorizontalEdge.Left).CellTemplate(new JS("stockCellTemplate"));
        @* columns.AddFor(m => m.UnitName).Caption("").Width(40).Alignment(HorizontalAlignment.Left); *@
        
        columns.AddFor(m => m.Soh).Caption("Số lượng").Width(70).Alignment(HorizontalAlignment.Right).Format("#,##0.00").CellTemplate(new JS("stockCellTemplate"));
        columns.AddFor(m => m.Ave).Caption("Giá TB").Width(64).Alignment(HorizontalAlignment.Right).Format("#,##0").CellTemplate(new JS("stockCellTemplate"));
        columns.AddFor(m => m.Value).Caption("Giá trị").Width(86).Alignment(HorizontalAlignment.Right).Format("#,##0").CellTemplate(new JS("stockCellTemplate"));
        
        columns.AddFor(m => m.Date).Caption("Ngày").Width(90).Alignment(HorizontalAlignment.Center).Format("dd/MM/yyyy").CellTemplate(new JS("stockCellTemplate"));
        columns.AddFor(m => m.Time).Caption("Giờ").Width(50).Alignment(HorizontalAlignment.Center).CellTemplate(new JS("stockCellTemplate"));
        columns.Add().Width(36).Alignment(HorizontalAlignment.Center).Fixed(true).FixedPosition(HorizontalEdge.Right).CellTemplate(new JS("addDataCellTemplate"));
    })
    .Editing(e => e.AllowUpdating(false))
    .Paging(p => p.Enabled(true).PageSize(100))
    .Summary(s => s
        .CalculateCustomSummary("calculateCustomSummary")
        .TotalItems(items =>
        {
            items.Add().ShowInColumn("Value")
                .Name("ValueSummary")
                .SummaryType(SummaryType.Custom)
                .DisplayFormat("{0}")
                .ValueFormat("#,##0");
        })
    )
)

<script>
    $(function () {
        $("#gridStock").first().prepend($("#divCaption"));
    });

    function gridContentReady() {
        $(".dx-header-row > td").css("text-align", "center");
    }

    function onCellPrepared(e) {
        if (e.rowType === 'group' && e.column.command === 'expand') {
            e.cellElement.css('display', 'none');
        }
    }

    function stockCellTemplate(container, options) {
        let itemType = options.data.ItemType;
        let cssColor = cssColorForItemType(itemType);
        let cssClass = ""; // cssColorForItemType(itemType);
        let style = "";
        let text = options.text;
        let lot = options.data.Lot;
        if (lot != null && lot != "") {
            style = "color: #666"
        } else {
            style = "color: #333"
        }
        
        if (options.column.dataField == "ItemName") {
            let iconText = "";
            if (lot != null && lot != "") {
                cssClass += " ps-3";
                text = text + " " + lot;
            } else {
                iconText = `<span class='${cssColor} me-2'>●</span>`;
            }
            text = `<a class='text-link' href='/stockcard?item=${options.data.Item}&lot=${options.data.Lot}&year=${options.data.Year}'>${iconText}<span style='${style}'>${text}</span></a>`;
        } else if (options.column.dataField == "Soh") {
            if (options.data.SohWarning) {
                // style = "color: var(--red)";
                text = `<div class='d-flex align-items-center'><div style='color: var(--red)'><i class="bi bi-exclamation-circle"></i></div><div style='margin-left:auto'>${text}</div></div>`;
            }
        }
        
        let html = `<div class='${cssClass}' style='${style}'>${text}</div>`
        container.html(html);
    }

    function addDataCellTemplate(container, options) {
        let lot = options.data.Lot;
        if (lot == null || lot == "") {
            let itemType = options.data.ItemType;
            let hint = (itemType == 1 ? "Nhập kho" : (itemType == 3 ? "Bán hàng" : "Chế biến"));
            let link = (itemType == 1 ? "receiving/new" : (itemType == 3 ? "bill/new" : "processing/new")) + "?item=" + options.data.Item + "&sourceurl=stock";
            let html = `<a class="text-link icon-link" href="${link}" title="${hint}"><span style='color: #666'><i class='dx-icon-add' style='font-size: 10px;'></i></span></a>`
            container.html(html);
        }
    }

    function calculateCustomSummary(options) {
        console.log(options);
        if (options.name === "ValueSummary") {
            if (options.summaryProcess === "start") {
                options.totalValue = 0;
            }
            if (options.summaryProcess === "calculate") {
                if (options.value.Lot == "") {
                    options.totalValue += options.value.Value;
                }
            }
            if (options.summaryProcess === "finalize") {
                //
            }
        }
    }
</script>