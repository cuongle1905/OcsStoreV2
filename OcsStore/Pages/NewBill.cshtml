@page "/sales/new"
@using OcsStore.Models
@model OcsStore.Pages.NewBillModel
@{
}
<style>
    #gridBill .dx-toolbar-items-container {
        display: none;
    }
    #timeBox {
        margin-left: 0.5rem;
    }
</style>
<div class="d-flex align-items-center mb-3">
    <a class="back-arrow" href="/sales"><i class="dx-icon-arrowleft"></i></a>
    <h4>TẠO BILL</h4>
</div>
<div class="d-flex align-items-center mb-3">
    <span class="me-2">Ngày:</span>
    @(Html.DevExtreme().DateBox()
        .ID("dateBox")
        .Width("9rem")
        .Height("2rem")
        .InputAttr("aria-label", "Date")
        .Type(DateBoxType.Date)
        .Value(DateTime.Today)
        .DisplayFormat("dd/MM/yyyy")
    )
    @(Html.DevExtreme().DateBox()
        .ID("timeBox")
        .Width("7rem")
        .Height("2rem")
        .Type(DateBoxType.Time)
        .Value(DateTime.Now)
        .DisplayFormat("HH:mm")
    )
</div>
@(
Html.DevExtreme().DataGrid<BillDetailView>()
    .ID("gridBill")
    .DataSource(d => d.Mvc().Controller("Sales").LoadAction("GetNewBillDetails").LoadMethod("POST"))
    .RemoteOperations(false)
    .ShowBorders(true)
    .ShowRowLines(true)
    .WordWrapEnabled(true)
    .Sorting(s => s.Mode(GridSortingMode.None))
    .Paging(p => p.PageSize(100))
    .Pager(p => p.Visible(false))
    .OnContentReady("gridContentReady")
    .Columns(columns =>
    {
        columns.AddFor(m => m.ItemName).Caption("Hàng hóa").Width(110).Alignment(HorizontalAlignment.Left).AllowEditing(false);
        columns.AddFor(m => m.Quantity).Caption("Số lượng").Width(60).Alignment(HorizontalAlignment.Right).SetCellValue("calculateRowTotal")
            .DataType(GridColumnDataType.Number) // Tells the grid to use dxNumberBox
            .Format("#,##0.00") // How the number displays outside of edit mode
            .EditorOptions(new { format = "#,##0.00", min = 0, max = 10000, step = 1, showSpinButtons = false });

        columns.AddFor(m => m.Unit).Caption("Đơn vị").Width(100).Alignment(HorizontalAlignment.Left)
            .Lookup(lookup => lookup
                .DataSource(ds => ds.Mvc().Controller("Item").LoadAction("GetUnits").LoadMethod("POST").Key("Id"))
                .ValueExpr("Id")
                .DisplayExpr("Name")
                .AllowClearing(false)
            )
            .EditorOptions(new { acceptCustomValue = false, searchEnabled = false });
            
        columns.AddFor(m => m.Price).Caption("Giá").Width(80).Alignment(HorizontalAlignment.Right).SetCellValue("calculateRowTotal")
            .DataType(GridColumnDataType.Number) // Tells the grid to use dxNumberBox
            .Format("#,##0") // How the number displays outside of edit mode
            .EditorOptions(new { format = "#,##0", min = 0, max = 10000000, step = 1000, showSpinButtons = false });

        columns.AddFor(m => m.Value).Caption("Thành tiền").Width(80).Alignment(HorizontalAlignment.Right).Format("#,##0").AllowEditing(false);

        columns.Add().Caption("Tồn kho").CssClass("blue").Columns(cols =>
        {
            cols.AddFor(m => m.Soh).Caption("SL tồn").Width(60).Alignment(HorizontalAlignment.Right).Format("#,##0.00").AllowEditing(false).CssClass("blue");
            cols.AddFor(m => m.StockUnitName).Caption("").Width(40).Alignment(HorizontalAlignment.Left).AllowEditing(false).CssClass("blue");
            cols.AddFor(m => m.Ave).Caption("Giá TB").Width(64).Alignment(HorizontalAlignment.Right).Format("#,##0").AllowEditing(false).CssClass("blue");
        });
        columns.AddFor(m => m.Note).Caption("Ghi chú").Width(140).Alignment(HorizontalAlignment.Left);
    })
    .Editing(e => e.AllowUpdating(true).Mode(GridEditMode.Batch))
    .Summary(s => s
        .TotalItems(items =>
        {
            items.AddFor(m => m.Value)
                 .SummaryType(SummaryType.Sum)
                 .DisplayFormat("{0}")
                 .ValueFormat("#,##0");
        })
        .RecalculateWhileEditing(true) // Crucial for dynamic total calculation
    )
)

<div id="divButtons" class="pt-3 text-end">
    <div id="divTotalAmount">Tổng tiền: 0</div>
    @(Html.DevExtreme().Button()
        .Text("Lưu")
        .Width(80)
        .Type(ButtonType.Default)
        .StylingMode(ButtonStylingMode.Contained)
        .Icon("save")
        .OnClick("save")
    )
</div>

<script>
    $(function () {
        $("#gridBill").first().append($("#divButtons"));
    });

    function gridContentReady() {
        let cells = $(".dx-header-row > td");
        cells.css("text-align", "center");
    }

    function calculateRowTotal(newData, value, currentRowData) {
        // 1. Update the field that triggered the change (e.g., Quantity or UnitPrice)
        this.defaultSetCellValue(newData, value);

        // 2. Derive dependent values
        var quantity = newData.Quantity !== undefined ? newData.Quantity : currentRowData.Quantity;
        var price = newData.Price !== undefined ? newData.Price : currentRowData.Price;

        // 3. Set the calculated field
        newData.Value = quantity * price;
    }

    function save() {
        let grid = $("#gridBill").dxDataGrid("instance");

        var details = []
        let rows = grid.getVisibleRows();
        for (const row of rows) {
            if (row.rowType == "data" && row.data.Quantity > 0) {
                // console.log(row.data); // The raw data object for this row
                details.push(row.data);
            }
        }
        console.log(details);

        if (details.length == 0) {
            DevExpress.ui.dialog.alert("Hãy nhập vào chi tiết.", "Cảnh báo");
            return;
        }

        DevExpress.ui.dialog.confirm("<i>Bạn có chắc chắn lưu thông tin?</i>", "Xác nhận").then(function(dialogResult) {
            if (dialogResult) {
                let date = $("#dateBox").dxDateBox("instance").option("value").toISOString();
                let time = $("#timeBox").dxDateBox("instance").option("text");

                $.ajax({
                    url: '@Url.Action("Save", "Sales")',
                    method: "POST",
                    data: { date: date, time: time, details: details },
                    success: function (result) {
                        DevExpress.ui.dialog.alert("Đã lưu dữ liệu.", "Thông báo").then(function(dialogResult) {
                            location.href = "/sales";
                        });
                    },
                    error: function (xhr, status, error) {
                        console.log("xhr", xhr, "status", status, "error", error);
                        DevExpress.ui.dialog.alert("Có lỗi xảy ra. Vui lòng thử lại sau.", "Cảnh báo");
                    }
                });
            }
        });
    }
</script>