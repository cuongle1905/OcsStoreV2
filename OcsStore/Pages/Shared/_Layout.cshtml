    <script src="~/js/devextreme/aspnet/dx.aspnet.data.js"></script>

    <script src="~/js/common.js"></script>

    <link href="~/css/devextreme/bootstrap.css" rel="stylesheet" />
    <link href="~/css/devextreme/dx.light.css" rel="stylesheet" />

    <link rel="stylesheet" href="/assets/bootstrap-icons.css?v1.1">
    <link rel="stylesheet" href="~/css/Site.css?v11" />
    <link rel="stylesheet" href="~/css/controls.css?v14" />
    <link rel="stylesheet" href="~/css/common.css?v1" />

    <link rel="preconnect" href="https://rsms.me/">
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
    
    @RenderSection("HeadSection", false)
</head>
@{
    bool hasToken = !string.IsNullOrEmpty(Session.Token(Context.Request));
    string fullName = "admin";
}
<body style="padding-top: 0.3rem;" spellcheck="false">
    <script>
        var isShowingUserMenu = false;
        var isShowingMobileMenu = false;
        var pageTitle = "";
        var goBackUrl = "";
        
        function menuContainerOnClick() {
            console.log("menuContainerOnClick");
            if (!isClickingMenuItem)
                showMenu(false);
        }

        function menuButtonClick() {
            showMenu(!isShowingMenuContent);
        }

        function menuItemClick(e) {
            console.log("menuItemClick");
            isClickingMenuItem = true;
            window.location.href = e.itemData.Link;
            showMenu(false);
        }

        function showMenu(show) {
            isShowingMenuContent = show;
            //var menu = $("#menu").dxMenu("instance").option("visible", show);
            $("#menu-container").css("visibility", show ? "visible" : "hidden");
            if (!show)
                $(':focus').blur();
        }

        function showHideMenu() {
            isShowingMobileMenu = !isShowingMobileMenu;
            $("#home-left-panel").css("visibility", isShowingMobileMenu ? "visible" : "hidden");
        }

        function menuItemTemplate(itemData, itemIndex, itemElement) {
            var div = $("<div>").addClass("menu-item").appendTo(itemElement);
            if (itemData.Id == 0) {
                div.html("<i class='dx-icon-menu'></i>")
            } else {
                div.text(itemData.text);
            }
        }

        function goBack() {
            history.go(-1);
        }

        function displayUserMenu() {
            var popup = $("#user-menu-popup").dxPopup("instance");
            if (!isShowingUserMenu) {
                popup.show();
                isShowingUserMenu = true;
            }
        }

        function userMenuPopupOnHidden() {
            setTimeout(function () {
                isShowingUserMenu = false;
            }, 300)
        
            $("#user-menu-popup").dxPopup("instance").hide();
            var popup = $("#change-user-password-popup").dxPopup("instance");
            popup.show();
        }

        function changeUserPasswordPopupOnShow() {
            var form = $("#change-user-password-popup-form").dxForm("instance");
            form.resetValues();
        }

        function saveUserPassword() {
            var form = $("#change-user-password-popup-form").dxForm("instance");
            var validationResult = form.validate();
            if (!validationResult.isValid)
                return;

            var currentPassword = form.getEditor("CurrentPassword").option("value").trim();
            var newPassword = form.getEditor("NewPassword").option("value").trim();
            var retypePassword = form.getEditor("RetypePassword").option("value").trim();
            if (newPassword == currentPassword) {
                DevExpress.ui.dialog.alert("Mật khẩu mới không được trùng với Mật khẩu cũ.", "Cảnh báo");
                return;
            }
            if (retypePassword != newPassword) {
                DevExpress.ui.dialog.alert("Gõ lại mật khẩu chưa đúng.", "Cảnh báo");
                return;
            }
            $.ajax({
                url: '@Url.Action("UpdatePassword", "Token")',
                method: "POST",
                data: { "newPassword": newPassword, "oldPassword": currentPassword },
                success: function (result) {
                    isSavingUser = false;
                    DevExpress.ui.dialog.alert("Đã cập nhật Mật khẩu thành công.", "Thông báo");
                    $("#change-user-password-popup").dxPopup("instance").hide();
                },
                error: function (xhr, status, error) {
                    console.log(xhr);
                    if (xhr.responseText == "incorrect old password") {
                        DevExpress.ui.dialog.alert("Mật khẩu cũ không chính xác.", "Cảnh báo");
                        return;
                    }
                    isSavingUser = false;
                    DevExpress.ui.dialog.alert("Không thể cập nhật Mật khẩu. Xin hãy thử lại sau.", "Cảnh báo");
                }
            });
        }

        function logoutButtonClicked() {
            $.ajax({
                url: '@Url.Action("Logout", "Token")',
                method: "POST",
                success: function (result) {
                    location.href = 'Index';
                },
                error: function (xhr, status, error) {
                }
            });
        }

    </script>
    <div style="position: fixed; left: 0; right: 0; top: 0; z-index: 1000">
        <div id="top-bar" class="d-flex align-items-center">
            @if (hasToken)
            {
                <a id="menu-icon" href="#" class="menu-link" onclick="showHideMenu()"><img src="~/images/logo_text_blue.png" style="width: 30px; height: 30px"/></a>
            }
            <div><a id="go-back" class="back-arrow" href="#"><i class="bi bi-chevron-left"></i></a></div>
            <div id="page-title" class="text-center flex-fill">
                UNI COFFEE
            </div>
        </div>
    </div>
    <main id="my-container" role="main">
        <div id="home-left-panel">
            @(Html.DevExtreme().ScrollView()
                .ID("home-left-scrollview")
                .ScrollByContent(true)
                .ScrollByThumb(true)
                .ShowScrollbar(ShowScrollbarMode.Never)
                .Content(@<text>
                    <div id="home-left-scrollview-content" style="">
                    @if (hasToken)
                    {
                        <a class="menu-link" href='~/stock'>
                            <div class="home-left-item">
                                <i class="dx-icon-box"></i>
                                <div class="home-left-item-text">
                                    <span>Tồn kho</span>
                                </div>
                            </div>
                        </a>
                        <a class="menu-link" href='~/receiving'>
                            <div class="home-left-item">
                                <i class="dx-icon-cart"></i>
                                <div class="home-left-item-text">
                                    <span>Nhập kho</span>
                                </div>
                            </div>
                        </a>
                        <a class="menu-link" href='~/processing'>
                            <div class="home-left-item">
                                <i class="dx-icon-preferences"></i>
                                <div class="home-left-item-text">
                                    <span>Chế biến</span>
                                </div>
                            </div>
                        </a>
                        <a class="menu-link" href='~/sales'>
                            <div class="home-left-item">
                                <i class="dx-icon-coffee"></i>
                                <div class="home-left-item-text">
                                    <span>Bán hàng</span>
                                </div>
                            </div>
                        </a>
                        <a class="menu-link" href='~/customer'>
                            <div class="home-left-item">
                                <i class="dx-icon-box"></i>
                                <div class="home-left-item-text">
                                    <span>Khách hàng - Công nợ</span>
                                </div>
                            </div>
                        </a>
                        <a class="menu-link" href='~/report'>
                            <div class="home-left-item">
                                <i class="dx-icon-chart"></i>
                                <div class="home-left-item-text">
                                    <span>Báo cáo</span>
                                </div>
                            </div>
                        </a>
                        <a class="menu-link" href='~/datamanagement'>
                            <div class="home-left-item">
                                <i class="bi bi-stack"></i>
                                <div class="home-left-item-text">
                                    <span>Quản lý dữ liệu</span>
                                </div>
                            </div>
                        </a>
                    }
                    </div>
                </text>)
            )
        </div>
        <div id="home-right-panel">
            @(Html.DevExtreme().Popup()
                .ID("user-menu-popup")
                .Position(config => config.My(HorizontalAlignment.Right, VerticalAlignment.Top).At(HorizontalAlignment.Right, VerticalAlignment.Top).Offset(-10, 52))
                .Shading(false)
                .Width(280)
                .Height(190)
                .ShowTitle(false)
                .ShowCloseButton(false)
                .HideOnOutsideClick(true)
                .Animation(config => config.Show(s => s.Duration(400)))
                .OnHidden("userMenuPopupOnHidden")
                .ContentTemplate(@<text>
                    <div id="user-menu-popup-fullname">@fullName</div>
                    @(Html.DevExtreme().Button()
                        .ID("change-password-button")
                        .Text("Đổi mật khẩu")
                        .Icon("key")
                        .Type(ButtonType.Normal)
                        .StylingMode(ButtonStylingMode.Contained)
                        .OnClick("changeUserPassword")
                    )
                    @(Html.DevExtreme().Button()
                        .ID("logout-button")
                        .Text("Đăng xuất")
                        .Icon("export")
                        .Type(ButtonType.Default)
                        .StylingMode(ButtonStylingMode.Contained)
                        .OnClick("logoutButtonClicked")
                    )
                </text>)
            )
            @(Html.DevExtreme().Popup()
                .ID("change-user-password-popup")
                .Title("Đổi mật khẩu")
                .Width(400)
                .Height(300)
                .Animation(config => config.Show(s => s.Duration(400)))
                .HideOnOutsideClick(false)
                .ShowCloseButton(true)
                .ToolbarItems(barItems =>
                {
                    barItems.Add()
                        .Toolbar(Toolbar.Bottom)
                        .Location(ToolbarItemLocation.Center)
                        .Widget(widget => widget.Button()
                        .Text("Bỏ qua")
                        .OnClick(@<text>
                            function () {
                            $("#change-user-password-popup").dxPopup("instance").hide();
                            }
                        </text>)
                    );
                    barItems.Add()
                        .Toolbar(Toolbar.Bottom)
                        .Location(ToolbarItemLocation.Center)
                        .Widget(widget => widget.Button()
                        .Icon("save")
                        .Text("Lưu")
                        .Type(ButtonType.Default)
                        .OnClick("saveUserPassword")
                        );
                })
                .OnShown("changeUserPasswordPopupOnShow")
                .ContentTemplate(@<text>
                    <form>
                    <input name="username" value="@fullName" type="hidden" />
                    @(Html.DevExtreme().Form()
                        .ID("change-user-password-popup-form")
                        .Items(items =>
                        {
                            items.AddSimple().DataField("CurrentPassword")
                                .Label(l => l.Alignment(HorizontalAlignment.Left).Text("Mật khẩu cũ"))
                                .Editor(e => e
                                .TextBox()
                                .Placeholder("Nhập vào Mật khẩu cũ")
                                .Mode(TextBoxMode.Password)
                                .ShowClearButton(true)
                                .HoverStateEnabled(true)
                                )
                                .ValidationRules(r => r.AddRequired().Message("Nhập vào Mật khẩu hiện tại"));
                            items.AddSimple().DataField("NewPassword")
                                .Label(l => l.Alignment(HorizontalAlignment.Left).Text("Mật khẩu mới"))
                                .Editor(e => e
                                .TextBox()
                                .Placeholder("Nhập vào Mật khẩu mới")
                                .Mode(TextBoxMode.Password)
                                .ShowClearButton(true)
                                .HoverStateEnabled(true)
                                )
                                .ValidationRules(r => r.AddRequired().Message("Nhập vào Mật khẩu mới"));
                            items.AddSimple().DataField("RetypePassword")
                                .Label(l => l.Alignment(HorizontalAlignment.Left).Text("Gõ lại mật khẩu"))
                                .Editor(e => e
                                .TextBox()
                                .Placeholder("Gõ lại mật khẩu mới")
                                .Mode(TextBoxMode.Password)
                                .ShowClearButton(true)
                                .HoverStateEnabled(true)
                                )
                            .ValidationRules(r => r.AddRequired().Message("Gõ lại mật khẩu"));
                        })
                    )
                    </form>
                    </text>)
                )
            <div id="main-content">
                @RenderBody()
            </div>
        </div>
    </main>
@*<a id="scroll-to-top-button" class="my-floating-button" href="#" onclick="scrollToTop()"><i class="dx-icon-chevronup"></i></a>*@

<script>
    $(function () {
        $("#page-title").html(pageTitle);

        if (goBackUrl != "") {
            $("#go-back").attr("href", goBackUrl);
        } else {
            $("#go-back").css("visibility", "hidden");
        }

        console.log("location.href", location.href);
        let links = $("#home-left-scrollview-content a.menu-link");
        for (const link of links) {
            const href = $(link).attr("href");
            // console.log("link", link, "href", href);
            if (location.href.toLowerCase().replace("/new?", "?").replace("/stockcard", "/stock").replace("/items", "/datamanagement").includes(href)) {
                console.log("link.children[0]", link.children[0]);
                link.children[0].classList.add("item-active");
                break;
            }
        }
    });
</script>
</body>

</html>