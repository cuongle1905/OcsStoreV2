    <style>
        :root {
            --bs-body-color: black;
            --bs-font-sans-serif: Arial, Roboto, sans-serif /* , Arial, "Segoe UI", "Helvetica Neue" */;
            /* --common-color-main: #9f224e;
            --common-color-main-dark: #801B3E;
            --common-color-main-light: #CD2B64; */
            --red: #fa3c4b;
            --green: #249851;
            --blue: #010125;
            --brown: #994c00;
        }
        .dx-button-mode-contained.dx-button-default.dx-state-hover {
            background-color: var(--common-color-main-light);
        }
        .dx-button-mode-contained.dx-button-default.dx-state-active, .dx-button-mode-contained.dx-button-default.dx-state-focused {
            background-color: var(--common-color-main-dark);
        }

        html {
            height: 100%;
            margin: 0px;
            padding: 0px;
            position: relative;
            font-size: 13.6px;
            font-family: Arial, Roboto, sans-serif /* , Arial, "Segoe UI", "Helvetica Neue" */;
        }

        .dx-widget {
            font-family: Arial, Roboto, sans-serif;
        }

        @@media (max-width: 1280px) {
            html {
                font-size: 13.6px;
            }
        }

        @@media (max-width: 1080px) {
            html {
                font-size: 13.6px;
            }
        }

        h6, .h6, h5, .h5, h4, .h4, h3, .h3, h2, .h2, h1, .h1 {
            font-weight: 600;
        }

        .bold {
            font-weight: 600;
        }

        .italic {
            font-style: italic;
        }

        .red {
            color: var(--red);
        }

        .dark-red {
            color: #a51030;
        }

        .gold {
            color: #c57d05;
        }

        .dark-green {
            color: #0a452f;
        }

        .green {
            color: var(--green);
        }

        .green2 {
            color: #006b2d;
        }

        .blue {
            color: #0e1d80; /*#0a1459*/
        }

        .dark-blue {
            color: var(--blue);
        }

        .orange {
            color: #ffa624;
        }

        .brown {
            color: var(--brown);
        }

        .gray {
            color: #707780;
        }

        .font-weight-600 {
            font-weight: 600;
        }

        .font-size-large1 {
            font-size: 1.1rem;
        }

        .outside-border, .border-outside, .border-all {
            border: 1px solid #e4e3e5;
            /*border-radius: 4px;*/
        }

        .top-border, .border-top {
            border-top: 1px solid #e4e3e5;
        }

        .left-border, .border-left {
            border-left: 1px solid #e4e3e5;
        }

        .right-border, .border-right {
            border-right: 1px solid #e4e3e5;
        }

        .bottom-border, .border-bottom {
            border-bottom: 1px solid #e4e3e5;
        }
        
        #my-container {
            position: absolute;
            top: 0px;
            left: 0;
            right: 0;
            bottom: 0;
        }
        #top-bar {
            background-color:var(--common-color-main-dark);
            font-weight: 600;
            height: 48px;
        }
        #top-bar, #top-bar a {
            color: white;
            text-align: center;
        }
        #language-button .dx-button-mode-text .dx-icon {
            color: white;
        }

        #home-container {
            position: absolute;
            top: 48px;
            right: 0;
            bottom: 0;
            left: 0;
        }

        #home-left-panel {
            position: fixed;
            top: 48px;
            bottom: 0;
            left: 0;
            width: 12rem;
            color: white;
            border-right: 1px solid #f1f1f3;
            background-color: var(--common-color-main-dark);
            /*box-shadow: 0 1px 3px 1px rgba(60, 64, 67, 0.4);*/
            z-index: 500;
        }

        #home-right-panel {
            position: absolute;
            top: 0px;
            right: 0;
            bottom: 0;
            left: 12rem;
        }
        @@media (max-width: 768px) {
            #top-bar { height: 40px; }
            #home-container, #home-left-panel { top: 41px; }
            #home-left-panel { left: 1px; width: 12rem; bottom: auto; visibility: hidden; }
            #home-right-panel { left: 0; }
        }
        a.menu-link, a.menu-link:hover, a.menu-link:active, a.menu-link:visited {
            color: white;
            text-decoration: none;
        }
        #home-left-panel a.menu-link:hover .home-left-item {
            background-color: #ebf5fd !important; /*#25547a*/
            color: #1e2dbe !important;
        }

        #home-left-scrollview {
            margin: 0;
        }

        .home-left-item {
            display: flex;
            align-items: center;
            padding: 0.8rem 0.5rem 0.8rem 0.5rem;
            border-bottom: solid #698faf 0.1px;
            font-weight: 600;
        }
        .home-left-item-text {
            margin-left: 0.3rem;
            padding: 0.2rem 0.2rem 0.2rem 0.3rem;
            width: 18rem;
        }

        .item-active, #home-left-panel a.menu-link:hover .item-active {
            font-weight: 600;
            background-color: #ebf5fd !important;
            color: #1e2dbe !important
        }
        
