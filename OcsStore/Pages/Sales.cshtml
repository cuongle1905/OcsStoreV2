@page "/sales"
@using OcsStore.Models
@model OcsStore.Pages.SalesModel
@{
}
<style>
</style>

<div id="divCaption" class="d-flex align-items-center pb-3">
    <h5>BÁN HÀNG</h5>
    <div id="divButtons" class="text-end ms-auto">
        @(Html.DevExtreme().Button()
            .Text("Tạo Bill")
            .Width(90)
            .Type(ButtonType.Default)
            .StylingMode(ButtonStylingMode.Contained)
            .Icon("add")
            .OnClick("addNew")
        )
    </div>
</div>

@(
Html.DevExtreme().DataGrid<BillView>()
    .ID("gridSales")
    .DataSource(d => d.Mvc().Controller("Sales").LoadAction("GetBills").LoadMethod("POST").Key("Id"))
    .RemoteOperations(false)
    .ShowBorders(true)
    .ShowRowLines(true)
    .WordWrapEnabled(true)
    .Sorting(s => s.Mode(GridSortingMode.None))
    .Paging(p => p.PageSize(100))
    .Pager(p => p.Visible(false))
    .OnContentReady("gridContentReady")
    .Columns(columns =>
    {
        columns.AddFor(m => m.Date).Caption("Ngày").Width(90).Alignment(HorizontalAlignment.Center).Format("dd/MM/yyyy").GroupIndex(0);
        columns.AddFor(m => m.Id).Caption("#").Width(40).Alignment(HorizontalAlignment.Center);
        columns.AddFor(m => m.Time).Caption("Giờ").Width(50).Alignment(HorizontalAlignment.Center);
        columns.AddFor(m => m.CustomerName).Caption("Khách hàng").Width(140).Alignment(HorizontalAlignment.Left);
        columns.AddFor(m => m.CustomerAddress).Caption("Địa chỉ KH").Width(60).Alignment(HorizontalAlignment.Left);
        columns.AddFor(m => m.Note).Caption("Ghi chú").Width(140).Alignment(HorizontalAlignment.Left);
        columns.AddFor(m => m.TotalValue).Caption("Tổng tiền").Width(70).Alignment(HorizontalAlignment.Right).Fixed(true).FixedPosition(HorizontalEdge.Right).Format("#,##0");
    })
    .Editing(e => e.AllowUpdating(false))
    .Paging(p => p.Enabled(true).PageSize(100))
)

<script>
    $(function () {
        $("#gridSales").first().prepend($("#divCaption"));
    });

    function gridContentReady() {
        $(".dx-header-row > td").css("text-align", "center");
    }

    function addNew() {
        location.href = "sales/new";
    }

    function onCellPrepared(e) {
        if (e.rowType === 'group' && e.column.command === 'expand') {
            e.cellElement.css('display', 'none');
        }
    }
</script>