@page
@using OcsStore.Models
@model OcsStore.Pages.IndexModel
@{
    IdName idName = new IdName();
}
<style>
    #content {
        margin-left: auto;
        margin-right: auto;
    }
    .note-label {
        padding-top: 0 !important;
    }
    .dx-field-item-label {
        padding-top: 0.5rem;
        padding-bottom: 0.4rem;
    }
    .flex-direction-column {
        flex-direction: column !important;
    }
    .widget {
        border-top: solid 4px #333;
        border-left: solid 1px #ccc;
        border-right: solid 1px #ccc;
        border-bottom: solid 1px #ccc;
        border-radius: 4px;
        margin: 0.5rem;
        padding: 1rem;
        text-align: center;
    }
    .widget-title {
        font-size: 1.2rem;
        font-weight: 600;
    }
    .widget-value {
        font-size: 1.6rem;
        font-weight: 600;
    }
    #eye-link i {
        width: 2rem;
        padding: 0.2rem 0.6rem 0.3rem 0.2rem;
        color: #555;
    }
    #eye-icon {
        margin-left: 0.6rem;
        margin-right: 1rem;
    }
    #login-button {
        margin-top: 2rem;
    }
</style>

<script>
    function inputValueChanged(e) {
        updateTextBoxBackground();
    }

    function inputKeyDown(e) {
        updateTextBoxBackground();
    }

    function updateTextBoxBackground() {
        let input = $("#username input")[0];
        let cssObj = window.getComputedStyle(input, null);
        let bgColor = cssObj.getPropertyValue("background-color");
        $("#username").css("background-color", bgColor);

        input = $("#password input")[0];
        cssObj = window.getComputedStyle(input, null);
        bgColor = cssObj.getPropertyValue("background-color");
        $("#password").css("background-color", bgColor);
    }
</script>

@if (string.IsNullOrEmpty(Session.Token(Request)))
{
    string controlHeight = "2.5rem";
    <div id="content" style="width: 21rem;">
        <div id="login-container">
            <div id="form-container" style="text-align:center;">
                <img class="login-icon" src="~/images/login-icon2.png" style="width: 5rem; margin: 1.5rem;" />
                @(Html.DevExtreme().Form<User>()
                    .ID("login-form")
                    .LabelLocation(FormLabelLocation.Top)
                    .Items(items => {
                        items.AddSimpleFor(m => m.Username)
                            .Label(l => l.Alignment(HorizontalAlignment.Left).Text("User name"))
                            .Editor(e => e
                                .TextBox()
                                .Height(controlHeight)
                                .ID("username")
                                .Placeholder("Nhập vào User name")
                                .ShowClearButton(true)
                                .HoverStateEnabled(true)
                                .OnValueChanged("inputValueChanged")
                                .OnKeyDown("inputKeyDown")
                                .Value("admin")
                            );
                        items.AddSimpleFor(m => m.Password)
                            .Label(l => l.Alignment(HorizontalAlignment.Left).Text("Mật khẩu"))
                            .Editor(e => e
                                .TextBox()
                                .ID("password")
                                .Height(controlHeight)
                                .Placeholder("Nhập vào Mật khẩu")
                                .Mode(TextBoxMode.Password)
                                .ShowClearButton(true)
                                .HoverStateEnabled(true)
                                .OnValueChanged("inputValueChanged")
                                .OnKeyDown("inputKeyDown")
                                .Value("1")
                            );
                        items.AddButton()
                            .HorizontalAlignment(HorizontalAlignment.Center)
                            .ButtonOptions(b => b.ID("login-button").Text("Đăng nhập")
                                .Width("100%")
                                .Height(controlHeight)
                                .Type(ButtonType.Default)
                                .Template(@<text>
                                    @(Html.DevExtreme().LoadIndicator()
                                    .ID("button-indicator")
                                    .IndicatorSrc("images/white-spinner.gif")
                                    .ElementAttr("style", "width: 16px; height: 16px; vertical-align: middle; margin-right: 6px")
                                    .Visible(false)
                                    )
                                    <span class="dx-button-text"><%- text %></span>
                                </text>)
                                .OnClick("login")
                            );
                        })
                    .OnContentReady(@<text>
                    function (e) { }
                    </text>)
                )
            </div>
        </div>
    </div>
}
else
{
    <div class="container">
        <div class="row">
            <div class="col-12 col-md-6 col-lg-4">
                <div class="widget" style="border-top: solid 4px #010125;">
                    <div class="widget-title">TỔNG DOANH THU</div>
                    <div class="widget-value">@(Model.BillTotal.ToString("N0") + " đ")</div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="widget" style="border-top: solid 4px #006b2d;">
                    <div class="widget-title">GIÁ TRỊ NHÂN XANH</div>
                    <div class="widget-value">@(Model.RecevingItemTotalValue.ToString("N0") + " đ")</div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="widget" style="border-top: solid 4px #994c00;">
                    <div class="widget-title">GIÁ TRỊ RANG</div>
                    <div class="widget-value">@(Model.ProcessingItemTotalValue.ToString("N0") + " đ")</div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="widget" style="border-top: solid 4px #a51030;">
                    <div class="widget-title">CÔNG NỢ KHÁCH HÀNG</div>
                    <div class="widget-value">@(Model.CustomerDebtTotal.ToString("N0") + " đ")</div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="widget" style="border-top: solid 4px #006b2d;">
                    <div class="widget-title">TỔNG CHI</div>
                    <div class="widget-value">@(Model.RecevingTotalValue.ToString("N0") + " đ")</div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="widget" style="border-top: solid 4px #010125;">
                    <div class="widget-title">LỢI NHUẬN RÒNG</div>
                    <div class="widget-value">@(Model.TotalProfit.ToString("N0") + " đ")</div>
                </div>
            </div>
        </div>
    </div>
}

<script>
    let isShowingPassword = false;
    pageTitle = "UNI COFFEE";
    let eyeSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" fill="currentColor"><path d="M288 32c-80.8 0-145.5 36.8-192.6 80.6-46.8 43.5-78.1 95.4-93 131.1-3.3 7.9-3.3 16.7 0 24.6 14.9 35.7 46.2 87.7 93 131.1 47.1 43.7 111.8 80.6 192.6 80.6s145.5-36.8 192.6-80.6c46.8-43.5 78.1-95.4 93-131.1 3.3-7.9 3.3-16.7 0-24.6-14.9-35.7-46.2-87.7-93-131.1-47.1-43.7-111.8-80.6-192.6-80.6zM144 256a144 144 0 1 1 288 0 144 144 0 1 1 -288 0zm144-64c0 35.3-28.7 64-64 64-11.5 0-22.3-3-31.7-8.4-1 10.9-.1 22.1 2.9 33.2 13.7 51.2 66.4 81.6 117.6 67.9s81.6-66.4 67.9-117.6c-12.2-45.7-55.5-74.8-101.1-70.8 5.3 9.3 8.4 20.1 8.4 31.7z"/></svg>`;
    let eyeSlashSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" fill="currentColor"><path d="M73 39.1C63.6 29.7 48.4 29.7 39.1 39.1C29.8 48.5 29.7 63.7 39 73.1L567 601.1C576.4 610.5 591.6 610.5 600.9 601.1C610.2 591.7 610.3 576.5 600.9 567.2L504.5 470.8C507.2 468.4 509.9 466 512.5 463.6C559.3 420.1 590.6 368.2 605.5 332.5C608.8 324.6 608.8 315.8 605.5 307.9C590.6 272.2 559.3 220.2 512.5 176.8C465.4 133.1 400.7 96.2 319.9 96.2C263.1 96.2 214.3 114.4 173.9 140.4L73 39.1zM236.5 202.7C260 185.9 288.9 176 320 176C399.5 176 464 240.5 464 320C464 351.1 454.1 379.9 437.3 403.5L402.6 368.8C415.3 347.4 419.6 321.1 412.7 295.1C399 243.9 346.3 213.5 295.1 227.2C286.5 229.5 278.4 232.9 271.1 237.2L236.4 202.5zM357.3 459.1C345.4 462.3 332.9 464 320 464C240.5 464 176 399.5 176 320C176 307.1 177.7 294.6 180.9 282.7L101.4 203.2C68.8 240 46.4 279 34.5 307.7C31.2 315.6 31.2 324.4 34.5 332.3C49.4 368 80.7 420 127.5 463.4C174.6 507.1 239.3 544 320.1 544C357.4 544 391.3 536.1 421.6 523.4L357.4 459.2z"/></svg>`;
    
    $(function () {
        let textEditorContainer = $("#password .dx-texteditor-container");
        console.log(textEditorContainer);
        textEditorContainer.append(`<div class='d-flex align-items-center'><a id='eye-link' href='#' onclick='showHidePassword()'><i class="dx-icon dx-svg-icon">${eyeSvg}</i></a></div>`);

        setTimeout(() => {
            updateTextBoxBackground();
        }, "500");
    });

    function showHidePassword() {
        isShowingPassword = !isShowingPassword;
        let passwordTextBox = $("#password").dxTextBox("instance");
        console.log(passwordTextBox);
        passwordTextBox.option("mode", isShowingPassword ? "text" : "password");
        let eyeLink = $("#eye-link i");
        eyeLink.html(isShowingPassword ? eyeSlashSvg : eyeSvg);
    }

    function login() {
        $("#button-indicator").dxLoadIndicator("option", "visible", true);
        var form = $("#login-form").dxForm("instance");
        var formData = form.option('formData');
        $.ajax({
            url: '@Url.Action("Post", "Token")',
            method: "POST",
            data: formData,
            success: function (result) {
                // location.href = "/customer";
                location.reload()
            },
            error: function (xhr, status, error) {
                console.log("xhr", xhr, "status", status, "error", error);
                $("#button-indicator").dxLoadIndicator("option", "visible", false);
                DevExpress.ui.dialog.alert("Đăng nhập không thành công.", "Cảnh báo");
            }
        });
    }
</script>